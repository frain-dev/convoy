#!/bin/sh

# git hook that runs before a commit
# this script will regenerate the swagger docs(openapi v3 soon) file

pwd

# regenerate only when the commit itself stages api/ or datastore/ changes;
# datastore structs feed the spec too (annotate_dtos + swag parseDependency).
# gate on the index, not the worktree, so untracked or unstaged files do not
# trigger regeneration on unrelated commits
changed=$(git diff --cached --name-only | grep -E '^(api|datastore)/')

echo "$changed"

# if changed is empty then exit, else regenerate the docs
if [ -z "$changed" ]
then
      exit 0
else
  # check required tools
  for tool in swag jq yq api-spec-converter openapi; do
    command -v "$tool" >/dev/null 2>&1 || { echo "❌ $tool not found. Run 'mise install' to install all required tools."; exit 1; }
  done

  # snapshot files already modified before the hook runs, so only hook-made
  # changes (x-nullable tags, swag fmt) are staged and unrelated WIP is not
  # swept into the commit; hash them to detect hook rewrites of dirty files
  pre_hook_dirty=$(mktemp)
  pre_hook_hashes=$(mktemp)
  git diff --name-only -- api/ datastore/ > "$pre_hook_dirty"
  while IFS= read -r f; do
    [ -f "$f" ] && shasum "$f"
  done < "$pre_hook_dirty" > "$pre_hook_hashes"

  # regenerate docs
  go run docs/annotate_dtos/main.go
  swag init --generatedTime --parseDependency --parseDependencyLevel 3 --parseInternal -g handlers/main.go -d api/ api/*
  swag fmt -d ./api
  bash docs/fix_openapi_spec.sh
  api-spec-converter --from=swagger_2 --to=openapi_3 -s yaml ./docs/swagger.yaml > ./docs/v3/openapi3.yaml
  api-spec-converter --from=swagger_2 --to=openapi_3 ./docs/swagger.json > ./docs/v3/openapi3.json
  # add region descriptions and EU server (swag only supports a single host)
  yq -i '.servers[0].description = "US Region" | .servers += [{"url": "https://eu.getconvoy.cloud/api", "description": "EU Region"}]' ./docs/v3/openapi3.yaml
  jq '.servers[0].description = "US Region" | .servers += [{"url": "https://eu.getconvoy.cloud/api", "description": "EU Region"}]' ./docs/v3/openapi3.json > ./docs/v3/openapi3.json.tmp && mv ./docs/v3/openapi3.json.tmp ./docs/v3/openapi3.json
  # Swagger 2.0 cannot express http bearer auth; upgrade the converted scheme so
  # generated SDK clients add the "Bearer " prefix instead of every caller.
  yq -i '.components.securitySchemes.ApiKeyAuth = {"type": "http", "scheme": "bearer"}' ./docs/v3/openapi3.yaml
  jq '.components.securitySchemes.ApiKeyAuth = {"type": "http", "scheme": "bearer"}' ./docs/v3/openapi3.json > ./docs/v3/openapi3.json.tmp && mv ./docs/v3/openapi3.json.tmp ./docs/v3/openapi3.json
  # validate specs
  openapi swagger validate ./docs/swagger.json
  openapi swagger validate ./docs/swagger.yaml
  openapi spec validate ./docs/v3/openapi3.yaml

  # fail closed if the hook rewrote a file that already had unstaged changes:
  # the regenerated spec was built from content this commit would not contain,
  # and auto-staging it would sweep unrelated WIP into the commit. the
  # developer must stage or stash those files and commit again
  rewritten=$(shasum -c "$pre_hook_hashes" 2>/dev/null | grep ': FAILED$' | cut -d: -f1)
  if [ -n "$rewritten" ]; then
    echo "❌ the docs hook rewrote files that already had unstaged changes:"
    echo "$rewritten"
    echo "Stage or stash these files, then commit again."
    rm -f "$pre_hook_dirty" "$pre_hook_hashes"
    exit 1
  fi

  # stage generated docs plus source files the hook itself modified
  # (x-nullable tags, swag fmt), so the committed tree regenerates the same
  # spec; files that were already dirty before the hook stay unstaged
  git add docs/
  for f in $(git diff --name-only -- api/ datastore/); do
    grep -qxF "$f" "$pre_hook_dirty" || git add "$f"
  done
  rm -f "$pre_hook_dirty" "$pre_hook_hashes"
fi

exit 0
